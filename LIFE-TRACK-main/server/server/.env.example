# Database
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=3306
DB_DIALECT=mysql
DATABASE_URL=

# JWT
JWT_SECRET=your_jwt_secret_key_here

#Token
ACCESS_TOKEN_SECRET=...
REFRESH_TOKEN_SECRET=...
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Google Gemini API
GEMINI_API_KEY=

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# AI CNN
AI_ENABLE=false
AI_MODEL_PATH=model_CNN/ecg_tfjs/model.json
AI_PREPROCESS_CONFIG_PATH=model_CNN/ecg/preprocess_config.json
AI_LABEL_MAP_PATH=model_CNN/ecg/label_map.json
AI_MAX_SIGNAL_SAMPLES=10000

# AI WORKER
REDIS_URL=redis://
AI_QUEUE_NAME=ecg-infer
AI_JOB_ATTEMPTS=3 # số lần retry nếu worker fail
AI_JOB_BACKOFF_MS=5000 # thời gian chờ trước khi retry

# MQTT
MQTT_ENABLE=true
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=ironman-server-dev
MQTT_TOPIC_TELEMETRY=devices/+/telemetry
MQTT_TOPIC_ACK_TEMPLATE=devices/{serial}/ack
MQTT_QOS=1
MQTT_ACK_ENABLE=true
MQTT_MAX_INFLIGHT=50
MQTT_DEDUPE_TTL_MS=600000
MQTT_DEDUPE_CLEANUP_INTERVAL_MS=60000
MQTT_MAX_PAYLOAD_BYTES=262144

# Caching
TELEMETRY_DEVICE_CACHE_TTL_MS=300000
TELEMETRY_RECIPIENT_CACHE_TTL_MS=60000
