generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BENH_NHAN @map("bệnh nhân")
  BAC_SI    @map("bác sĩ")
  GIA_DINH  @map("gia đình")
  ADMIN     @map("admin")
}

enum DeviceStatus {
  DANG_HOAT_DONG  @map("đang hoạt động")
  NGUNG_HOAT_DONG @map("ngừng hoạt động")
}

enum AccessRole {
  BAC_SI   @map("bác sĩ")
  GIA_DINH @map("gia đình")
}

enum AccessStatus {
  pending
  accepted
  rejected
}

enum ChatRole {
  user
  bot
}

enum NotificationType {
  ALERT
  ACCESS_REQUEST
  ACCESS_RESPONSE
  ACCESS_REVOKE
  DIRECT_MESSAGE
  MEDICATION_REMINDER
  APPOINTMENT_UPDATE
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum AppointmentType {
  ONLINE
  OFFLINE
}

enum PaymentStatus {
  FREE
  PENDING
  PAID
}

enum DoctorHireStatus {
  PENDING_DOCTOR_APPROVAL
  ACTIVE
  REJECTED
  CANCELLED
  EXPIRED
}

enum MedicationLogStatus {
  PENDING
  TAKEN
  MISSED
  SKIPPED
}

model User {
  user_id       Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          UserRole @default(BENH_NHAN)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @updatedAt @map("updated_at")

  consultation_fee Int? @default(0)

  devices                Device[]
  alerts                 Alert[]
  patientReports         Report[]                @relation("PatientReports")
  doctorReports          Report[]                @relation("DoctorReports")
  chatLogs               ChatLog[]
  sentDirectMessages     DirectMessage[]         @relation("DirectSender")
  receivedDirectMessages DirectMessage[]         @relation("DirectReceiver")
  sharedPatients         AccessPermission[]      @relation("SharedPatients")
  sharedViewers          AccessPermission[]      @relation("SharedViewers")
  phrOverview            PhrOverview?
  patientVisits          MedicalVisit[]          @relation("PatientVisits")
  doctorVisits           MedicalVisit[]          @relation("DoctorVisits")
  notificationsAuthored  Notification[]          @relation("NotificationActor")
  notificationRecipients NotificationRecipient[]
  refreshTokens          RefreshToken[]
  appointmentsAsPatient  Appointment[]           @relation("PatientAppointments")
  appointmentsAsDoctor   Appointment[]           @relation("DoctorAppointments")
  medicationPlans        MedicationPlan[]         @relation("PatientMedicationPlans")
  medicationPlansAsDoctor MedicationPlan[]        @relation("DoctorMedicationPlans")
  medicationLogs         MedicationLog[]
  doctorAvailabilities   DoctorAvailability[]     @relation("DoctorAvailabilities")
  doctorTimeOffs         DoctorTimeOff[]          @relation("DoctorTimeOffs")
  doctorProfile          DoctorProfile?           @relation("DoctorProfile")
  doctorHiresAsPatient   DoctorHire[]             @relation("PatientDoctorHires")
  doctorHiresAsDoctor    DoctorHire[]             @relation("DoctorDoctorHires")

  @@map("users")
}

model Device {
  device_id     Int          @id @default(autoincrement())
  user_id       Int
  serial_number String       @unique
  status        DeviceStatus @default(DANG_HOAT_DONG)
  created_at    DateTime     @default(now()) @map("created_at")
  updated_at    DateTime     @updatedAt @map("updated_at")

  user     User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  readings Reading[]

  @@map("devices")
}

model Reading {
  reading_id        Int       @id @default(autoincrement())
  device_id         Int
  timestamp         DateTime  @default(now())
  heart_rate        Int
  ecg_signal        Json
  abnormal_detected Boolean   @default(false)
  ai_result         String?
  ai_status         String    @default("PENDING")
  ai_error          String?   @db.Text
  ai_completed_at   DateTime?

  device Device  @relation(fields: [device_id], references: [device_id], onDelete: Cascade, onUpdate: Cascade)
  alerts Alert[]

  @@map("readings")
}

model Alert {
  alert_id             Int      @id @default(autoincrement())
  user_id              Int
  reading_id           Int
  alert_type           String
  message              String   @db.Text
  segment_start_sample Int?
  segment_end_sample   Int?
  timestamp            DateTime @default(now())
  resolved             Boolean  @default(false)

  user    User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  reading Reading @relation(fields: [reading_id], references: [reading_id], onDelete: Cascade, onUpdate: Cascade)

  @@map("alerts")
}

model Report {
  report_id  Int      @id @default(autoincrement())
  user_id    Int
  doctor_id  Int?
  summary    String   @db.Text
  created_at DateTime @default(now()) @map("created_at")

  patient User  @relation("PatientReports", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  doctor  User? @relation("DoctorReports", fields: [doctor_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade)

  @@map("reports")
}

model ChatLog {
  chat_id   Int      @id @default(autoincrement())
  user_id   Int
  role      ChatRole
  message   String   @db.Text
  timestamp DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)

  @@map("chat_logs")
}

model DirectMessage {
  message_id       Int      @id @default(autoincrement())
  conversation_key String   @db.VarChar(64)
  sender_id        Int
  receiver_id      Int
  message          String   @db.Text
  is_read          Boolean  @default(false)
  created_at       DateTime @default(now()) @map("created_at")

  sender   User @relation("DirectSender", fields: [sender_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)
  receiver User @relation("DirectReceiver", fields: [receiver_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([conversation_key, created_at, message_id])
  @@index([receiver_id, sender_id, is_read])
  @@map("direct_messages")
}

model AccessPermission {
  permission_id Int          @id @default(autoincrement())
  patient_id    Int
  viewer_id     Int
  role          AccessRole
  status        AccessStatus @default(pending)
  created_at    DateTime     @default(now()) @map("created_at")
  updated_at    DateTime     @updatedAt @map("updated_at")

  patient User @relation("SharedPatients", fields: [patient_id], references: [user_id], onDelete: Cascade)
  viewer  User @relation("SharedViewers", fields: [viewer_id], references: [user_id], onDelete: Cascade)

  @@map("access_permissions")
}

model DoctorProfile {
  profile_id   Int      @id @default(autoincrement())
  doctor_id    Int      @unique
  specialty    String?  @db.VarChar(255)
  title        String?  @db.VarChar(255)
  hospital     String?  @db.VarChar(255)
  location     String?  @db.VarChar(255)
  bio          String?  @db.Text
  avatar_url   String?  @db.VarChar(500)
  hire_price   Int      @default(0)
  is_listed    Boolean  @default(true)
  created_at   DateTime @default(now()) @map("created_at")
  updated_at   DateTime @updatedAt @map("updated_at")

  doctor User @relation("DoctorProfile", fields: [doctor_id], references: [user_id], onDelete: Cascade)

  @@index([is_listed])
  @@map("doctor_profiles")
}

model DoctorHire {
  hire_id              Int              @id @default(autoincrement())
  patient_id           Int
  doctor_id            Int
  status               DoctorHireStatus @default(PENDING_DOCTOR_APPROVAL)
  price_snapshot       Int              @default(0)
  can_view_ehr         Boolean          @default(false)
  can_view_medications Boolean          @default(false)
  can_view_ecg         Boolean          @default(false)
  requested_at         DateTime         @default(now())
  approved_at          DateTime?
  rejected_at          DateTime?
  cancelled_at         DateTime?
  created_at           DateTime         @default(now()) @map("created_at")
  updated_at           DateTime         @updatedAt @map("updated_at")

  patient User @relation("PatientDoctorHires", fields: [patient_id], references: [user_id], onDelete: Cascade)
  doctor  User @relation("DoctorDoctorHires", fields: [doctor_id], references: [user_id], onDelete: Cascade)

  @@unique([patient_id, doctor_id])
  @@index([doctor_id, status])
  @@index([patient_id, status])
  @@map("doctor_hires")
}

model PhrOverview {
  overview_id      Int      @id @default(autoincrement())
  user_id          Int      @unique
  personal_info    Json?
  vitals           Json?
  medical_history  Json?
  clinical_results Json?
  created_at       DateTime @default(now()) @map("created_at")
  updated_at       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("phr_overviews")
}

model MedicalVisit {
  visit_id      Int       @id @default(autoincrement())
  user_id       Int
  doctor_id     Int?
  facility      String?   @db.VarChar(255)
  doctor_name   String?   @db.VarChar(255)
  visit_date    DateTime  @default(now())
  
  diagnosis     String    @db.VarChar(255)
  reason        String?   @db.Text
  diagnosis_details String? @db.Text
  tests         Json?
  prescription  Json?
  advice        String?   @db.Text
  appointment   String?   @db.Text

  created_at    DateTime  @default(now()) @map("created_at")
  updated_at    DateTime  @updatedAt @map("updated_at")
  deleted_at    DateTime?

  patient User  @relation("PatientVisits", fields: [user_id], references: [user_id], onDelete: Cascade)
  doctor  User? @relation("DoctorVisits", fields: [doctor_id], references: [user_id], onDelete: SetNull)

  @@map("medical_visits")
}

model Notification {
  notification_id Int              @id @default(autoincrement())
  type            NotificationType
  title           String
  message         String           @db.Text
  actor_id        Int?
  entity_type     String?
  entity_id       Int?
  payload         Json?
  created_at      DateTime         @default(now()) @map("created_at")

  actor      User?                   @relation("NotificationActor", fields: [actor_id], references: [user_id], onDelete: SetNull, onUpdate: Cascade)
  recipients NotificationRecipient[]

  @@index([created_at])
  @@map("notifications")
}

model RefreshToken {
  token_id   Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique @db.VarChar(191)
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

model NotificationRecipient {
  recipient_id    Int       @id @default(autoincrement())
  notification_id Int
  user_id         Int
  is_read         Boolean   @default(false)
  read_at         DateTime?
  created_at      DateTime  @default(now()) @map("created_at")

  notification Notification @relation(fields: [notification_id], references: [notification_id], onDelete: Cascade, onUpdate: Cascade)
  user         User         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([notification_id, user_id])
  @@index([user_id, is_read, created_at])
  @@index([notification_id])
  @@map("notification_recipients")
}

model Appointment {
  appointment_id Int               @id @default(autoincrement())
  patient_id     Int
  doctor_id      Int
  
  appointment_date DateTime        
  start_time     DateTime          
  end_time       DateTime          
  
  status         AppointmentStatus @default(PENDING)
  type           AppointmentType
  reason         String            @db.Text
  patient_attachment_url String?   @db.VarChar(500)
  
  meeting_url    String?           @db.VarChar(500) 
  doctor_note    String?           @db.Text
  status_reason  String?           @db.Text
  
  fee            Int               @default(0)      
  payment_status PaymentStatus     @default(FREE)
  
  created_at     DateTime          @default(now()) @map("created_at")
  updated_at     DateTime          @updatedAt @map("updated_at")

  patient User @relation("PatientAppointments", fields: [patient_id], references: [user_id], onDelete: Cascade)
  doctor  User @relation("DoctorAppointments", fields: [doctor_id], references: [user_id], onDelete: Cascade)

  @@index([doctor_id, start_time, end_time])
  @@index([patient_id, start_time])
  @@index([status, start_time])
  @@map("appointments")
}

model DoctorAvailability {
  availability_id Int      @id @default(autoincrement())
  doctor_id       Int
  day_of_week     Int
  start_time      String   @db.VarChar(5)
  end_time        String   @db.VarChar(5)
  slot_minutes    Int      @default(30)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")

  doctor User @relation("DoctorAvailabilities", fields: [doctor_id], references: [user_id], onDelete: Cascade)

  @@index([doctor_id, day_of_week, is_active])
  @@map("doctor_availabilities")
}

model DoctorTimeOff {
  time_off_id Int      @id @default(autoincrement())
  doctor_id   Int
  start_time  DateTime
  end_time    DateTime
  reason      String?  @db.Text
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")

  doctor User @relation("DoctorTimeOffs", fields: [doctor_id], references: [user_id], onDelete: Cascade)

  @@index([doctor_id, start_time, end_time])
  @@map("doctor_time_offs")
}

model MedicationPlan {
  plan_id    Int          @id @default(autoincrement())
  user_id    Int
  doctor_id  Int?         
  title      String       
  start_date DateTime
  end_date   DateTime?
  notes      String?      @db.Text
  is_active  Boolean      @default(true)
  
  created_at DateTime     @default(now()) @map("created_at")
  updated_at DateTime     @updatedAt @map("updated_at")

  user        User         @relation("PatientMedicationPlans", fields: [user_id], references: [user_id], onDelete: Cascade)
  doctor      User?        @relation("DoctorMedicationPlans", fields: [doctor_id], references: [user_id], onDelete: SetNull)
  medications Medication[]

  @@index([user_id, is_active, start_date])
  @@index([doctor_id])
  @@map("medication_plans")
}

model Medication {
  medication_id Int      @id @default(autoincrement())
  plan_id       Int
  name          String   
  dosage        String   
  times         Json     
  
  plan MedicationPlan  @relation(fields: [plan_id], references: [plan_id], onDelete: Cascade)
  logs MedicationLog[]

  @@map("medications")
}

model MedicationLog {
  log_id         Int                 @id @default(autoincrement())
  user_id        Int
  medication_id  Int
  scheduled_time DateTime            
  taken_at       DateTime?           
  reminded_at    DateTime?
  status         MedicationLogStatus @default(PENDING)

  user       User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  medication Medication @relation(fields: [medication_id], references: [medication_id], onDelete: Cascade)

  @@unique([medication_id, scheduled_time]) 
  @@index([user_id, scheduled_time])
  @@index([status, scheduled_time])
  @@map("medication_logs")
}
